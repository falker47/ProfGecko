# ============================================================
# PROF. GALLADE - Configurazione
# ============================================================
# Per switchare modalita, commenta un blocco LLM e decommenta
# l'altro. Le embedding restano sempre locali (HuggingFace).
# ============================================================

# --- LLM: Gemini (produzione, richiede API key) ---
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=your-google-api-key-here

# --- LLM: Ollama (testing locale, zero costi) ---
#LLM_PROVIDER=ollama
#LLM_MODEL=gemma3:12b

# --- Parametri LLM comuni ---
LLM_TEMPERATURE=0.3

# --- Embedding (sempre locale, nessuna API) ---
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=pokemon_knowledge

# --- Retriever ---
RETRIEVER_K=12

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- App ---
APP_DEBUG=false
